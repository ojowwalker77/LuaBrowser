#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DERIVED_DATA="${DERIVED_DATA:-$ROOT_DIR/.derivedData-check}"

"$ROOT_DIR/script/bootstrap"
# The unit bundle is app-hosted. The prebuilt Chromium host currently exits
# before XCTest connects on headless runners, so the required deterministic
# gate compiles every test without launching the application. Hosted execution
# remains blocked until the framework can bootstrap reliably in CI.
xcodebuild build-for-testing \
  -project "$ROOT_DIR/Phi.xcodeproj" \
  -scheme PhiBrowser-OpenSource \
  -configuration OpenSource \
  -destination 'platform=macOS,arch=arm64' \
  -derivedDataPath "$DERIVED_DATA" \
  -only-testing:PhiBrowserTests \
  CODE_SIGNING_ALLOWED=NO \
  CODE_SIGNING_REQUIRED=NO
